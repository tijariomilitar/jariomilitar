		<div class="box b1 container h-center margin-top-15">
			<div class="mobile-box b3-4 container radius-5 height-60 pointer"
				onclick="lib.openExternalLink('https://produto.mercadolivre.com.br/MLB-2084384887-case-capa-transporte-rifle-fuzil-airsoft-ja-rio-militar-_JM')"
